<!-- ══════════════════════════════════════════════
     <dialog> — Insert Link / Note Modal
══════════════════════════════════════════════ -->
<dialog id="insert-dialog" aria-labelledby="dialog-title" aria-modal="true">
  <div class="dialog-header">
    <h2 id="dialog-title">Insert Element</h2>
    <button class="btn-t" style="color:rgba(255,255,255,0.6);"
      onclick="document.getElementById('insert-dialog').close()"
      title="Close dialog">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <div class="dialog-body">
    <p>Choose what to insert into your document at the current cursor position.</p>

    <fieldset>
      <legend>Insert Type</legend>
      <div class="radio-group">
        <label><input type="radio" name="insert-type" value="link" checked /> Hyperlink</label>
        <label><input type="radio" name="insert-type" value="note" /> Callout Note</label>
        <label><input type="radio" name="insert-type" value="quote" /> Block Quote</label>
      </div>
    </fieldset>

    <div class="dialog-field">
      <label for="link-text">Display Text</label>
      <input type="text" id="link-text" placeholder="e.g. Click here" />
    </div>
    <div class="dialog-field">
      <label for="link-url">URL / Content</label>
      <input type="text" id="link-url" placeholder="https://example.com" />
    </div>
    <div class="dialog-field" style="flex-direction:row;align-items:center;gap:10px;">
      <input type="checkbox" id="open-new-tab" style="width:auto;" />
      <label for="open-new-tab" style="font-size:13px;text-transform:none;letter-spacing:0;cursor:pointer;">
        Open in new tab
      </label>
    </div>
  </div>
  <div class="dialog-footer">
    <button class="btn-ghost" onclick="document.getElementById('insert-dialog').close()">Cancel</button>
    <button class="btn-primary" onclick="
      var txt = document.getElementById('link-text').value || 'Link';
      var url = document.getElementById('link-url').value || '#';
      var newTab = document.getElementById('open-new-tab').checked;
      var html = '<a href=\'' + url + '\'' + (newTab ? ' target=\'_blank\'' : '') + '>' + txt + '</a>';
      document.getElementById('editor').focus();
      document.execCommand('insertHTML', false, html);
      document.getElementById('insert-dialog').close();
    ">Insert</button>
  </div>
</dialog>
<!-- Word count script -->
<script>
  const editor = document.getElementById('editor');
  const wc = document.getElementById('word-count');
  editor.addEventListener('input', () => {
    const text = editor.innerText.trim();
    const count = text ? text.split(/\s+/).length : 0;
    wc.textContent = count + (count === 1 ? ' word' : ' words');
  });
</script>
</body>
